[Unit]
Description=BigV-twins web chat UI (赛博大V, FastAPI on 127.0.0.1:8001)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/dtl/projects/BigV-twins
ExecStart=/home/dtl/miniconda3/envs/bigv-twins/bin/python -m bigv_twins.web.app
Restart=on-failure
RestartSec=5s
StandardOutput=append:/home/dtl/projects/BigV-twins/logs/web.log
StandardError=append:/home/dtl/projects/BigV-twins/logs/web.log

[Install]
WantedBy=default.target
