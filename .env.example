# Read-only path to the existing Zhihu archive's SQLite database.
# This file is opened in read-only mode (`?mode=ro&immutable=1`) — never written.
ZHIHU_DB_PATH=/home/dtl/projects/zhihu/data/zhihu.db

# Where per-blogger sqlite-vec indices are kept.
TWINS_DIR=/home/dtl/projects/BigV-twins/twins

# Where blogger persona summaries (markdown) live.
PERSONAS_DIR=/home/dtl/projects/BigV-twins/personas

# HuggingFace embedding model. BGE-base-zh-v1.5 is the default for this server
# (~400MB, runs comfortably on 4-CPU / 7GB-RAM box). Swap to BAAI/bge-large-zh-v1.5
# or BAAI/bge-m3 if RAM allows and you want stronger retrieval.
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EMBEDDING_DIM=768

# Chunking: target chunk size in characters (Chinese), overlap in characters.
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# MCP server bind address. OpenClaw runs on the same host, so loopback only.
MCP_HOST=127.0.0.1
MCP_PORT=8770

# Web chat UI (赛博大V) — only used if you run `bigv-twins-web`.
# WEB_SECRET_KEY must be a stable random string (deploy.sh generates one).
WEB_HOST=127.0.0.1
WEB_PORT=8001
WEB_SECRET_KEY=

# OpenClaw gateway URL (chat UI talks to /v1/chat/completions here).
# Token is auto-read from ~/.openclaw/openclaw.json at runtime.
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# China-friendly Hugging Face mirror (set automatically by .env loader)
HF_ENDPOINT=https://hf-mirror.com

# Anthropic key — only needed for the one-shot persona generation script if
# OpenClaw is unavailable. Otherwise leave blank.
ANTHROPIC_API_KEY=
